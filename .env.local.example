# ===== Supabase =====
# จาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...   # "anon public" key (ใช้ฝั่งฟอร์ม insert ได้อย่างเดียว)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # "service_role" key (ลับ! ใช้ฝั่ง server อ่านข้อมูลแดชบอร์ด)

# ===== Dashboard =====
# รหัสผ่านสำหรับเข้าหน้า /dashboard (ตั้งเองให้เดายาก)
DASHBOARD_PASSWORD=change-me-please
